name: Install Database Packs

on:
  workflow_dispatch:

permissions:
  contents: write

jobs:
  install-packs:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout Database Repo
        uses: actions/checkout@v4

      - name: Check database packs exist
        run: |
          ls database_pack*.zip >/dev/null 2>&1 || {
            echo "ERROR: No database_pack*.zip files found in repo root"
            exit 1
          }

      - name: Extract all database packs
        run: |
          for pack in $(ls database_pack*.zip | sort -V); do
            echo "Installing $pack"

            rm -rf _pack
            mkdir _pack
            unzip -o "$pack" -d _pack

            echo "Pack contents:"
            find _pack -maxdepth 4 -type f

            cp -R _pack/. .

            rm -rf _pack
            rm -f "$pack"
          done

      - name: Commit database updates
        run: |
          git config user.name "github-actions"
          git config user.email "github-actions@github.com"

          git add .

          if git diff --cached --quiet; then
            echo "No database changes to commit"
          else
            git commit -m "Install database packs"
            git push
          fi
